{
	"name": "fftt-api/php-client",
	"description": "Client PHP non-officiel de l'API FFTT 🏓",
	"version": "1.0.0",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Aurélien Devaux",
			"email": "37188045+aureldvx@users.noreply.github.com"
		}
	],
	"require": {
		"php": ">=8.3",
		"ext-curl": "*",
		"nesbot/carbon": "3.11.1"
	},
	"require-dev": {
		"laravel/pint": "1.27.1",
		"pestphp/pest": "4.4.1",
		"phpstan/phpstan": "2.1.40",
		"rector/rector": "2.3.8"
	},
	"autoload": {
		"psr-4": {
			"FFTTApi\\": "src/"
		}
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"config": {
		"sort-packages": true,
		"preferred-install": "dist",
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
	},
	"scripts": {
		"lint": "pint --parallel",
		"refactor": "rector --dry-run",
		"analyze": "phpstan analyse --ansi --memory-limit=1G",
		"test": "pest --colors=always --coverage --parallel"
	}
}
